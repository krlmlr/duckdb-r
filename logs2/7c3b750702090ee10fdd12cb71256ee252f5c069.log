2026-05-13T01:15:05.1309655Z [36;1m  patterns <- gsub(rx, "^\\1$", files[has_snapshot])[0m
2026-05-13T01:15:05.1310005Z [36;1m  pattern <- paste0(patterns, collapse = "|")[0m
2026-05-13T01:15:05.1310448Z [36;1m  tryCatch([0m
