2026-05-13T01:15:05.1333448Z [36;1m        print(failures$result)[0m
2026-05-13T01:15:05.1333707Z [36;1m        testthat::snapshot_accept()[0m
2026-05-13T01:15:05.1334034Z [36;1m        writeLines("changed=true", Sys.getenv("GITHUB_OUTPUT"))[0m
2026-05-13T01:15:05.1334358Z [36;1m      } else {[0m
2026-05-13T01:15:05.1334606Z [36;1m        writeLines("Snapshot tests ran successfully.")[0m
2026-05-13T01:15:05.1334896Z [36;1m      }[0m
2026-05-13T01:15:05.1335051Z [36;1m    },[0m
2026-05-13T01:15:05.1335220Z [36;1m    error = print[0m
2026-05-13T01:15:05.1335411Z [36;1m  )[0m
2026-05-13T01:15:05.1335561Z [36;1m} else {[0m
