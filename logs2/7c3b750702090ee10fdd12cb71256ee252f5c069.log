2026-05-13T01:15:05.1331259Z [36;1m      result <- as.data.frame(testthat::test_local(pattern = pattern, reporter = "location", stop_on_failure = FALSE))[0m
2026-05-13T01:15:05.1331916Z [36;1m      failures <- result[result$failed + result$warning > 0, ][0m
2026-05-13T01:15:05.1332259Z [36;1m      print(failures)[0m
2026-05-13T01:15:05.1332492Z [36;1m      if (nrow(failures) > 0) {[0m
