2026-06-20T02:40:35.3649160Z > # CRAN guard
2026-06-20T02:40:35.3649310Z > #
2026-06-20T02:40:35.3649670Z > # The duckdb test suite exercises DuckDB's bundled C++ engine, which is too heavy
2026-06-20T02:40:35.3650200Z > # for CRAN's check farm, and checks were very fragile in the past. We therefore
2026-06-20T02:40:35.3650750Z > # keep it off on CRAN but run it automatically on GitHub Actions (GITHUB_ACTIONS)
2026-06-20T02:40:35.3651330Z > # and on r-universe (MY_UNIVERSE). An explicit DUCKDB_R_RUN_TESTS opts in
2026-06-20T02:40:35.3651830Z > # (true-ish) or out (false-ish) and always wins; otherwise we fall back to those.
2026-06-20T02:40:35.3652350Z > # This check is intentionally inlined here (rather than calling into the package)
2026-06-20T02:40:35.3652750Z > # so the guard is obvious and self-contained.
2026-06-20T02:40:35.3653140Z > run_tests <- tolower(trimws(Sys.getenv("DUCKDB_R_RUN_TESTS", "")))
2026-06-20T02:40:35.3653390Z > 
2026-06-20T02:40:35.3653600Z > if (run_tests %in% c("true", "1", "yes", "on")) {
2026-06-20T02:40:35.3653830Z +   run <- TRUE
2026-06-20T02:40:35.3654090Z + } else if (run_tests %in% c("false", "0", "no", "off")) {
2026-06-20T02:40:35.3654330Z +   run <- FALSE
2026-06-20T02:40:35.3654480Z + } else {
2026-06-20T02:40:35.3654770Z +   run <- tolower(trimws(Sys.getenv("GITHUB_ACTIONS", ""))) == "true" ||
2026-06-20T02:40:35.3655140Z +     nzchar(trimws(Sys.getenv("MY_UNIVERSE", "")))
2026-06-20T02:40:35.3655350Z + }
2026-06-20T02:40:35.3655450Z > 
2026-06-20T02:40:35.3655580Z > if (run) {
2026-06-20T02:40:35.3655760Z +   test_check("duckdb")
2026-06-20T02:40:35.3655920Z + } else {
2026-06-20T02:40:35.3656060Z +   message(
2026-06-20T02:40:35.3656190Z +     "\n",
2026-06-20T02:40:35.3656340Z +     strrep("=", 78),
2026-06-20T02:40:35.3656500Z +     "\n",
2026-06-20T02:40:35.3656690Z +     "Skipping the duckdb test suite.\n",
2026-06-20T02:40:35.3657030Z +     "\n",
2026-06-20T02:40:35.3657380Z +     "The duckdb tests exercise DuckDB's bundled C++ engine and are deliberately\n",
2026-06-20T02:40:35.3657870Z +     "NOT run on CRAN. They run automatically on GitHub Actions (including\n",
2026-06-20T02:40:35.3658350Z +     "r-universe). This keeps check time and resource usage on CRAN within\n",
2026-06-20T02:40:35.3658860Z +     "acceptable limits and helps release duckdb in a predictable and controlled\n",
2026-06-20T02:40:35.3659170Z +     "manner.\n",
2026-06-20T02:40:35.3659330Z +     "\n",
2026-06-20T02:40:35.3659670Z +     "This is intentional, not an oversight. duckdb has an extensive test suite\n",
2026-06-20T02:40:35.3660200Z +     "that runs continuously in our own CI; see <https://github.com/duckdb/duckdb-r>.\n",
2026-06-20T02:40:35.3660530Z +     "\n",
2026-06-20T02:40:35.3660870Z +     "To run the test suite locally, set the environment variable before checking:\n",
