2026-06-20T02:40:35.3050460Z Loading required package: DBI
2026-06-20T02:40:35.3050680Z > 
2026-06-20T02:40:35.3051000Z > # CRAN guard
2026-06-20T02:40:35.3051240Z > #
2026-06-20T02:40:35.3051760Z > # The duckdb test suite exercises DuckDB's bundled C++ engine, which is too heavy
2026-06-20T02:40:35.3052430Z > # for CRAN's check farm, and checks were very fragile in the past. We therefore
2026-06-20T02:40:35.3053010Z > # keep it off on CRAN but run it automatically on GitHub Actions (GITHUB_ACTIONS)
2026-06-20T02:40:35.3053650Z > # and on r-universe (MY_UNIVERSE). An explicit DUCKDB_R_RUN_TESTS opts in
2026-06-20T02:40:35.3054230Z > # (true-ish) or out (false-ish) and always wins; otherwise we fall back to those.
2026-06-20T02:40:35.3054860Z > # This check is intentionally inlined here (rather than calling into the package)
2026-06-20T02:40:35.3055410Z > # so the guard is obvious and self-contained.
2026-06-20T02:40:35.3055860Z > run_tests <- tolower(trimws(Sys.getenv("DUCKDB_R_RUN_TESTS", "")))
2026-06-20T02:40:35.3056250Z > 
2026-06-20T02:40:35.3056590Z > if (run_tests %in% c("true", "1", "yes", "on")) {
2026-06-20T02:40:35.3057110Z +   run <- TRUE
2026-06-20T02:40:35.3057420Z + } else if (run_tests %in% c("false", "0", "no", "off")) {
2026-06-20T02:40:35.3057820Z +   run <- FALSE
2026-06-20T02:40:35.3058030Z + } else {
2026-06-20T02:40:35.3058470Z +   run <- tolower(trimws(Sys.getenv("GITHUB_ACTIONS", ""))) == "true" ||
2026-06-20T02:40:35.3058880Z +     nzchar(trimws(Sys.getenv("MY_UNIVERSE", "")))
2026-06-20T02:40:35.3059230Z + }
2026-06-20T02:40:35.3059400Z > 
2026-06-20T02:40:35.3059600Z > if (run) {
2026-06-20T02:40:35.3059990Z +   test_check("duckdb")
2026-06-20T02:40:35.3060210Z + } else {
2026-06-20T02:40:35.3060510Z +   message(
2026-06-20T02:40:35.3060730Z +     "\n",
2026-06-20T02:40:35.3060950Z +     strrep("=", 78),
2026-06-20T02:40:35.3061180Z +     "\n",
2026-06-20T02:40:35.3061510Z +     "Skipping the duckdb test suite.\n",
2026-06-20T02:40:35.3061730Z +     "\n",
2026-06-20T02:40:35.3062200Z +     "The duckdb tests exercise DuckDB's bundled C++ engine and are deliberately\n",
2026-06-20T02:40:35.3062740Z +     "NOT run on CRAN. They run automatically on GitHub Actions (including\n",
2026-06-20T02:40:35.3063290Z +     "r-universe). This keeps check time and resource usage on CRAN within\n",
2026-06-20T02:40:35.3063870Z +     "acceptable limits and helps release duckdb in a predictable and controlled\n",
2026-06-20T02:40:35.3064320Z +     "manner.\n",
2026-06-20T02:40:35.3064570Z +     "\n",
2026-06-20T02:40:35.3064950Z +     "This is intentional, not an oversight. duckdb has an extensive test suite\n",
2026-06-20T02:40:35.3065610Z +     "that runs continuously in our own CI; see <https://github.com/duckdb/duckdb-r>.\n",
2026-06-20T02:40:35.3065930Z +     "\n",
2026-06-20T02:40:35.3066390Z +     "To run the test suite locally, set the environment variable before checking:\n",
2026-06-20T02:40:35.3067010Z +     "  Sys.setenv(DUCKDB_R_RUN_TESTS = \"true\")    # from within R, or\n",
2026-06-20T02:40:35.3067450Z +     "  DUCKDB_R_RUN_TESTS=true R CMD check ...      # from the shell\n",
2026-06-20T02:40:35.3067760Z +     strrep("=", 78),
2026-06-20T02:40:35.3067940Z +     "\n"
2026-06-20T02:40:35.3068230Z +   )
2026-06-20T02:40:35.3068360Z + }
