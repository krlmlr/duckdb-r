2026-06-19T02:30:42.9524070Z > library(testthat)
2026-06-19T02:30:42.9524303Z > library(duckdb)
2026-06-19T02:30:42.9524558Z Loading required package: DBI
2026-06-19T02:30:42.9524799Z > 
2026-06-19T02:30:42.9524998Z > # CRAN guard
2026-06-19T02:30:42.9525186Z > #
2026-06-19T02:30:42.9525596Z > # The duckdb test suite exercises DuckDB's bundled C++ engine, which is too heavy
2026-06-19T02:30:42.9526219Z > # for CRAN's check farm, and checks were very fragile in the past. We therefore
2026-06-19T02:30:42.9526821Z > # keep it off on CRAN but run it automatically on GitHub Actions (GITHUB_ACTIONS)
2026-06-19T02:30:42.9527408Z > # and on r-universe (MY_UNIVERSE). An explicit DUCKDB_R_RUN_TESTS opts in
2026-06-19T02:30:42.9528000Z > # (true-ish) or out (false-ish) and always wins; otherwise we fall back to those.
2026-06-19T02:30:42.9528744Z > # This check is intentionally inlined here (rather than calling into the package)
2026-06-19T02:30:42.9529509Z > # so the guard is obvious and self-contained.
2026-06-19T02:30:42.9529980Z > run_tests <- tolower(trimws(Sys.getenv("DUCKDB_R_RUN_TESTS", "")))
2026-06-19T02:30:42.9530334Z > 
2026-06-19T02:30:42.9530612Z > if (run_tests %in% c("true", "1", "yes", "on")) {
2026-06-19T02:30:42.9530918Z +   run <- TRUE
2026-06-19T02:30:42.9531244Z + } else if (run_tests %in% c("false", "0", "no", "off")) {
2026-06-19T02:30:42.9531577Z +   run <- FALSE
2026-06-19T02:30:42.9531786Z + } else {
2026-06-19T02:30:42.9532155Z +   run <- tolower(trimws(Sys.getenv("GITHUB_ACTIONS", ""))) == "true" ||
2026-06-19T02:30:42.9532615Z +     nzchar(trimws(Sys.getenv("MY_UNIVERSE", "")))
2026-06-19T02:30:42.9532900Z + }
2026-06-19T02:30:42.9533081Z > 
2026-06-19T02:30:42.9533273Z > if (run) {
2026-06-19T02:30:42.9533501Z +   test_check("duckdb")
2026-06-19T02:30:42.9533741Z + } else {
2026-06-19T02:30:42.9533941Z +   message(
2026-06-19T02:30:42.9534142Z +     "\n",
2026-06-19T02:30:42.9534363Z +     strrep("=", 78),
2026-06-19T02:30:42.9534594Z +     "\n",
2026-06-19T02:30:42.9534844Z +     "Skipping the duckdb test suite.\n",
2026-06-19T02:30:42.9535137Z +     "\n",
2026-06-19T02:30:42.9535553Z +     "The duckdb tests exercise DuckDB's bundled C++ engine and are deliberately\n",
2026-06-19T02:30:42.9536160Z +     "NOT run on CRAN. They run automatically on GitHub Actions (including\n",
2026-06-19T02:30:42.9536753Z +     "r-universe). This keeps check time and resource usage on CRAN within\n",
2026-06-19T02:30:42.9537373Z +     "acceptable limits and helps release duckdb in a predictable and controlled\n",
2026-06-19T02:30:42.9537810Z +     "manner.\n",
2026-06-19T02:30:42.9538030Z +     "\n",
2026-06-19T02:30:42.9538445Z +     "This is intentional, not an oversight. duckdb has an extensive test suite\n",
2026-06-19T02:30:42.9539374Z +     "that runs continuously in our own CI; see <https://github.com/duckdb/duckdb-r>.\n",
2026-06-19T02:30:42.9539823Z +     "\n",
2026-06-19T02:30:42.9540250Z +     "To run the test suite locally, set the environment variable before checking:\n",
